{{ define "main" }}
<section class="review-list-container">
  <h1 class="list-title">所有評論</h1>
  
  <div class="album-grid">
    {{ range .Pages.ByDate.Reverse }} <a href="{{ .RelPermalink }}" class="album-card">
      <div class="card-image-wrapper">
        {{ $cover := .Resources.GetMatch "cover.jpg" }}
        {{ if $cover }}
          {{ $thumb := $cover.Fill "400x400 webp" }} <img src="{{ $thumb.RelPermalink }}" alt="{{ .Title }}" loading="lazy">
        {{ end }}
        
        <div class="card-score">{{ .Params.score }}</div>
      </div>
      
      <div class="card-info">
        <span class="card-artist">{{ .Params.artist }}</span>
        <span class="card-title">{{ .Title }}</span>
      </div>
    </a>
    {{ end }}
  </div>
</section>
{{ end }}
