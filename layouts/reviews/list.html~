{{ define "main" }}
{{ $style := resources.Get "css/review.css" | minify }}
<link rel="stylesheet" href="{{ $style.RelPermalink }}">

<section class="review-list-container">
  <div class="album-grid">
    {{ range (.Pages.ByParam "score").Reverse }}
    <a href="{{ .RelPermalink }}" class="album-card">
      <div class="card-image-wrapper">
        {{ $cover := .Resources.GetMatch "cover.jpg" }}
        {{ with $cover }}
          {{ $thumb := .Fill "400x400 webp" }}
          <img src="{{ $thumb.RelPermalink }}" alt="{{ .Title }}">
        {{ end }}
        <div class="card-score">{{ .Params.score }}</div>
      </div>
      <div class="card-info">
        <span class="card-artist">{{ .Params.artist }}</span>
        <span class="card-title">{{ .Title }}</span>
      </div>
    </a>
    {{ end }}
  </div>
</section>
{{ end }}
