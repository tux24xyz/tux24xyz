<div class="post-meta">

  {{ with .Date }}
    <span class="date">
      <i class="fa-solid fa-calendar"></i>
      <time datetime="{{ .Format "2006-01-02T15:04:05Z07:00" }}">
        {{ .Format (.Site.Params.dateFormat | default "2006-01-02") }}
      </time>
    </span>
  {{ end }}

  {{ with .ReadingTime }}
    <span class="reading-time">
      <i class="fa-solid fa-clock"></i>
      {{ . }} min read
    </span>
  {{ end }}

  {{ with .Params.tags }}
    <div class="tags">
      {{ range . }}
        <a class="tag" href="{{ "tags/" | relURL }}{{ . | urlize }}">
          #{{ . }}
        </a>
      {{ end }}
    </div>
  {{ end }}

</div>
